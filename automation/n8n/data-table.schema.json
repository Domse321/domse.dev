  "columns": [
    {"name":"stable_key","type":"string"},{"name":"osm_relation_id","type":"string"},{"name":"route_name","type":"string"},
    {"name":"region","type":"string"},{"name":"bike_type","type":"string"},{"name":"osm_url","type":"string"},
    {"name":"geometry_json","type":"string"},{"name":"geometry_points","type":"number"},{"name":"distance_km","type":"number"},
    {"name":"max_gap_km","type":"number"},{"name":"tag_distance_km","type":"number"},{"name":"closure_km","type":"number"},{"name":"closure_ratio","type":"number"},
    {"name":"geometry_ratio","type":"number"},{"name":"bounds_json","type":"string"},{"name":"evidence_score","type":"number"},
    {"name":"evidence_json","type":"string"},{"name":"gate_reasons","type":"string"},{"name":"image_title","type":"string"},
    {"name":"image_thumb_url","type":"string"},{"name":"image_creator","type":"string"},{"name":"image_license","type":"string"},
    {"name":"image_license_url","type":"string"},{"name":"image_page_url","type":"string"},{"name":"image_distance_km","type":"number"},
    {"name":"image_candidates_json","type":"string"},{"name":"partial_failure","type":"boolean"},{"name":"http_status_json","type":"string"},
    {"name":"observed_at","type":"date"},{"name":"run_id","type":"string"}
